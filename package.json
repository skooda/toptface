{
  "name": "toptface",
  "author": "Pavel Skoda",
  "version": "1.0.0",
  "keywords": ["pebble-app"],
  "sdk": {
    "version": "^4.9"
  },
  "pebble": {
    "displayName": "toptface",
    "uuid": "cd0fb816-9172-488a-8dd8-4969ed7f1e7f",
    "sdkVersion": "3",
    "projectType": "native",
    "targetPlatforms": ["diorite"],
    "watchapp": {
      "watchface": true
    },
    "resources": {
      "media": [
        {
          "type": "font",
          "name": "FONT_PIXEL_TIME_42",
          "file": "fonts/pixel.ttf",
          "characterRegex": "[0-9:]"
        },
        {
          "type": "font",
          "name": "FONT_PIXEL_DATE_18",
          "file": "fonts/pixel.ttf",
          "characterRegex": "[A-Z]"
        },
        {
          "type": "font",
          "name": "FONT_PIXEL_TOTP_24",
          "file": "fonts/pixel.ttf",
          "characterRegex": "[0-9]"
        }
      ]
    }
  },
  "dependencies": {},
  "devDependencies": {}
}
