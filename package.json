{
  "name": "toptface",
  "author": "Pavel Skoda",
  "version": "1.0.0",
  "keywords": ["pebble-app"],
  "sdk": {
    "version": "^4.9"
  },
  "pebble": {
    "displayName": "toptface",
    "uuid": "cd0fb816-9172-488a-8dd8-4969ed7f1e7f",
    "sdkVersion": "3",
    "projectType": "native",
    "targetPlatforms": ["diorite"],
    "watchapp": {
      "watchface": true
    },
    "enableMultiJS": true,
    "capabilities": ["configurable"],
    "messageKeys": [
      "KEY_SECRET"
    ],
    "resources": {
      "media": [
        {
          "type": "font",
          "name": "FONT_PIXEL_TIME_24",
          "file": "fonts/pixel.ttf",
          "characterRegex": "[0-9: ]"
        },
        {
          "type": "font",
          "name": "FONT_PIXEL_DATE_8",
          "file": "fonts/pixel.ttf",
          "characterRegex": "[0-9.]"
        },
        {
          "type": "font",
          "name": "FONT_PIXEL_TOTP_8",
          "file": "fonts/pixel.ttf",
          "characterRegex": "[-0-9]"
        }
      ]
    }
  },
  "dependencies": {},
  "devDependencies": {}
}
